{
  "manifest_version": 3,
  "name": "FocusGuard",
  "version": "1.0",
  "permissions": ["tabs", "storage", "offscreen"],
  "host_permissions": ["<all_urls>"],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_popup": "popup.html"
  },

  "content_scripts": [
    {
      "matches": ["*://www.youtube.com/*"],
      "js": ["content.js"]
    }
  ]
}
